# 운영 서버(.env) 템플릿 — 서버에서 이 내용을 복사해 `.env` 로 만들고 값 채우기.
# ⚠️ 절대 git 에 커밋 금지 (.gitignore 가 .env 를 이미 제외함).

# DB 비밀번호 (강력하게)
POSTGRES_PASSWORD=change-this-to-a-strong-password

# 세션 서명 키 — 아래 명령으로 생성해 붙여넣기:
#   openssl rand -base64 48
SECRET_KEY=paste-a-long-random-string-here

# OpenAI (회의 전사·AI 추출용). 없으면 그 기능만 비활성.
OPENAI_API_KEY=sk-...

# 서비스 도메인 (HTTPS 자동 발급 대상). DNS A레코드가 이 서버 IP를 가리켜야 함.
#   예: weave.example.com  또는  무료 서브도메인 something.duckdns.org
DOMAIN=weave.example.com

# --- 선택: Google Drive / Google 로그인 ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://weave.example.com/drive/callback
# GOOGLE_AUTH_REDIRECT_URI=https://weave.example.com/auth/google/callback
